{
  "name": "inventory-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create inventory-db",
    "db:migrate": "wrangler d1 execute inventory-db --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute inventory-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.75.0"
  }
}
